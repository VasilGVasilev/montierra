---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { t } from '../i18n/translations';
---

<Layout title="Montierra — Описание | Description">
  <Header currentPage="description" />

  <main class="flex-1">
    <!-- Hero -->
    <section class="relative pt-32 pb-20 md:pt-40 md:pb-28 bg-charcoal overflow-hidden">
      <div class="absolute inset-0 opacity-10">
        <svg class="absolute bottom-0 w-full h-1/2" viewBox="0 0 1440 320" preserveAspectRatio="none">
          <path fill="#c9a96e" d="M0,96L80,112C160,128,320,160,480,176C640,192,800,192,960,176C1120,160,1280,128,1360,112L1440,96L1440,320L0,320Z" />
        </svg>
      </div>
      <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
        <p class="text-gold text-sm uppercase tracking-[0.3em] mb-4 reveal">Montierra</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold text-white mb-6 reveal reveal-delay-1">
          <span data-lang-bg>{t.description.hero.title.bg}</span>
          <span data-lang-en>{t.description.hero.title.en}</span>
        </h1>
        <p class="text-lg text-white/60 max-w-2xl mx-auto reveal reveal-delay-2">
          <span data-lang-bg>{t.description.hero.subtitle.bg}</span>
          <span data-lang-en>{t.description.hero.subtitle.en}</span>
        </p>
      </div>
    </section>

    <!-- Concept Section -->
    <section class="py-20 md:py-28 bg-cream">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
          <div class="reveal">
            <p class="text-gold text-sm uppercase tracking-[0.2em] mb-4">01</p>
            <h2 class="text-3xl md:text-4xl font-heading font-semibold text-charcoal mb-6">
              <span data-lang-bg>{t.description.concept.title.bg}</span>
              <span data-lang-en>{t.description.concept.title.en}</span>
            </h2>
            <p class="text-stone leading-relaxed text-lg">
              <span data-lang-bg>{t.description.concept.text.bg}</span>
              <span data-lang-en>{t.description.concept.text.en}</span>
            </p>
          </div>
          <div class="aspect-[4/3] bg-gradient-to-br from-charcoal-light to-charcoal rounded-sm overflow-hidden reveal reveal-delay-1">
            <div class="w-full h-full flex items-center justify-center text-gold/20">
              <svg class="w-20 h-20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="0.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Architecture Section -->
    <section class="py-20 md:py-28 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
          <div class="order-2 lg:order-1 aspect-[4/3] bg-gradient-to-br from-cream-dark to-cream rounded-sm overflow-hidden reveal">
            <div class="w-full h-full flex items-center justify-center text-gold/30">
              <svg class="w-20 h-20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="0.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
          </div>
          <div class="order-1 lg:order-2 reveal reveal-delay-1">
            <p class="text-gold text-sm uppercase tracking-[0.2em] mb-4">02</p>
            <h2 class="text-3xl md:text-4xl font-heading font-semibold text-charcoal mb-6">
              <span data-lang-bg>{t.description.architecture.title.bg}</span>
              <span data-lang-en>{t.description.architecture.title.en}</span>
            </h2>
            <p class="text-stone leading-relaxed text-lg">
              <span data-lang-bg>{t.description.architecture.text.bg}</span>
              <span data-lang-en>{t.description.architecture.text.en}</span>
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Location Section -->
    <section class="py-20 md:py-28 bg-cream">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
          <div class="reveal">
            <p class="text-gold text-sm uppercase tracking-[0.2em] mb-4">03</p>
            <h2 class="text-3xl md:text-4xl font-heading font-semibold text-charcoal mb-6">
              <span data-lang-bg>{t.description.location.title.bg}</span>
              <span data-lang-en>{t.description.location.title.en}</span>
            </h2>
            <p class="text-stone leading-relaxed text-lg">
              <span data-lang-bg>{t.description.location.text.bg}</span>
              <span data-lang-en>{t.description.location.text.en}</span>
            </p>
          </div>
          <div class="aspect-[4/3] rounded-sm overflow-hidden reveal reveal-delay-1">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d11729.345!2d23.29!3d42.64!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x40aa856e9c4292ef%3A0x400a01269bf5e60!2sDragalevtsi%2C%20Sofia!5e0!3m2!1sen!2sbg!4v1"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Montierra Location"
            ></iframe>
          </div>
        </div>
      </div>
    </section>

    <!-- Key Specs -->
    <section class="py-16 md:py-20 bg-charcoal">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl md:text-3xl font-heading font-semibold text-white text-center mb-12 reveal">
          <span data-lang-bg>{t.description.specs.title.bg}</span>
          <span data-lang-en>{t.description.specs.title.en}</span>
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          {t.description.specs.items.map((item, i) => (
            <div class={`text-center reveal reveal-delay-${i + 1}`}>
              <p class="text-3xl md:text-4xl font-heading font-bold text-gold">{item.value}</p>
              <p class="text-white/60 text-sm mt-2 uppercase tracking-wider">
                <span data-lang-bg>{item.label.bg}</span>
                <span data-lang-en>{item.label.en}</span>
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-20 md:py-28 bg-cream text-center">
      <div class="max-w-3xl mx-auto px-4 reveal">
        <h2 class="text-3xl md:text-4xl font-heading font-semibold text-charcoal mb-6">
          <span data-lang-bg>Заинтересувани ли сте?</span>
          <span data-lang-en>Interested?</span>
        </h2>
        <p class="text-stone mb-8 text-lg">
          <span data-lang-bg>Свържете се с нас за допълнителна информация или уговорете оглед на имота.</span>
          <span data-lang-en>Contact us for additional information or schedule a property viewing.</span>
        </p>
        <a
          href="/contacts/"
          class="inline-block px-8 py-4 bg-gold text-charcoal font-semibold text-sm uppercase tracking-wider hover:bg-gold-light transition-all duration-300"
        >
          <span data-lang-bg>Свържете се с нас</span>
          <span data-lang-en>Contact Us</span>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
