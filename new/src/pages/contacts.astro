---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { t } from '../i18n/translations';
import { apartments } from '../data/apartments';
---

<Layout title="Montierra — Контакти | Contacts">
  <Header currentPage="contacts" />

  <main class="flex-1">
    <!-- Hero -->
    <section class="relative pt-32 pb-20 md:pt-40 md:pb-28 bg-charcoal overflow-hidden">
      <div class="absolute inset-0 opacity-10">
        <svg class="absolute bottom-0 w-full h-1/2" viewBox="0 0 1440 320" preserveAspectRatio="none">
          <path fill="#c9a96e" d="M0,288L80,272C160,256,320,224,480,213.3C640,203,800,213,960,224C1120,235,1280,245,1360,250.7L1440,256L1440,320L0,320Z" />
        </svg>
      </div>
      <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
        <p class="text-gold text-sm uppercase tracking-[0.3em] mb-4 reveal">Montierra</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold text-white mb-6 reveal reveal-delay-1">
          <span data-lang-bg>{t.contacts.hero.title.bg}</span>
          <span data-lang-en>{t.contacts.hero.title.en}</span>
        </h1>
        <p class="text-lg text-white/60 max-w-2xl mx-auto reveal reveal-delay-2">
          <span data-lang-bg>{t.contacts.hero.subtitle.bg}</span>
          <span data-lang-en>{t.contacts.hero.subtitle.en}</span>
        </p>
      </div>
    </section>

    <!-- Contact Content -->
    <section class="py-20 md:py-28 bg-cream">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
          <!-- Contact Form -->
          <div class="reveal">
            <h2 class="text-2xl md:text-3xl font-heading font-semibold text-charcoal mb-8">
              <span data-lang-bg>Изпратете запитване</span>
              <span data-lang-en>Send an Inquiry</span>
            </h2>
            <form id="contact-form" class="space-y-5" action="https://formspree.io/f/YOUR_FORM_ID" method="POST">
              <!-- Name -->
              <div>
                <label class="block text-sm font-medium text-charcoal mb-1.5">
                  <span data-lang-bg>{t.contacts.form.name.bg}</span>
                  <span data-lang-en>{t.contacts.form.name.en}</span>
                  <span class="text-sold">*</span>
                </label>
                <input
                  type="text"
                  name="name"
                  required
                  class="w-full px-4 py-3 bg-white border border-cream-dark rounded-sm focus:border-gold focus:outline-none transition-colors text-charcoal"
                />
              </div>

              <!-- Email -->
              <div>
                <label class="block text-sm font-medium text-charcoal mb-1.5">
                  <span data-lang-bg>{t.contacts.form.email.bg}</span>
                  <span data-lang-en>{t.contacts.form.email.en}</span>
                  <span class="text-sold">*</span>
                </label>
                <input
                  type="email"
                  name="email"
                  required
                  class="w-full px-4 py-3 bg-white border border-cream-dark rounded-sm focus:border-gold focus:outline-none transition-colors text-charcoal"
                />
              </div>

              <!-- Phone -->
              <div>
                <label class="block text-sm font-medium text-charcoal mb-1.5">
                  <span data-lang-bg>{t.contacts.form.phone.bg}</span>
                  <span data-lang-en>{t.contacts.form.phone.en}</span>
                </label>
                <input
                  type="tel"
                  name="phone"
                  class="w-full px-4 py-3 bg-white border border-cream-dark rounded-sm focus:border-gold focus:outline-none transition-colors text-charcoal"
                />
              </div>

              <!-- Apartment interest -->
              <div>
                <label class="block text-sm font-medium text-charcoal mb-1.5">
                  <span data-lang-bg>{t.contacts.form.apartment.bg}</span>
                  <span data-lang-en>{t.contacts.form.apartment.en}</span>
                </label>
                <select
                  name="apartment"
                  class="w-full px-4 py-3 bg-white border border-cream-dark rounded-sm focus:border-gold focus:outline-none transition-colors text-charcoal"
                >
                  <option value="">
                    — 
                  </option>
                  {apartments.map((apt) => (
                    <option value={apt.number}>
                      {apt.number} — {apt.area}m² ({apt.typeLabel.en})
                    </option>
                  ))}
                </select>
              </div>

              <!-- Message -->
              <div>
                <label class="block text-sm font-medium text-charcoal mb-1.5">
                  <span data-lang-bg>{t.contacts.form.message.bg}</span>
                  <span data-lang-en>{t.contacts.form.message.en}</span>
                  <span class="text-sold">*</span>
                </label>
                <textarea
                  name="message"
                  required
                  rows="5"
                  class="w-full px-4 py-3 bg-white border border-cream-dark rounded-sm focus:border-gold focus:outline-none transition-colors text-charcoal resize-none"
                ></textarea>
              </div>

              <!-- Submit -->
              <button
                type="submit"
                id="submit-btn"
                class="w-full py-3.5 bg-gold text-charcoal font-semibold text-sm uppercase tracking-wider hover:bg-gold-light transition-all rounded-sm"
              >
                <span data-lang-bg>{t.contacts.form.send.bg}</span>
                <span data-lang-en>{t.contacts.form.send.en}</span>
              </button>

              <!-- Status message -->
              <div id="form-status" class="hidden text-center py-3 rounded-sm text-sm font-medium"></div>
            </form>
          </div>

          <!-- Contact Info -->
          <div class="reveal reveal-delay-1">
            <h2 class="text-2xl md:text-3xl font-heading font-semibold text-charcoal mb-8">
              <span data-lang-bg>Информация за контакт</span>
              <span data-lang-en>Contact Information</span>
            </h2>

            <div class="space-y-6 mb-10">
              <!-- Address -->
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 border border-gold/30 rounded-full flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-charcoal mb-1">
                    <span data-lang-bg>Адрес</span>
                    <span data-lang-en>Address</span>
                  </p>
                  <p class="text-stone">
                    <span data-lang-bg>{t.contacts.info.address.bg}</span>
                    <span data-lang-en>{t.contacts.info.address.en}</span>
                  </p>
                </div>
              </div>

              <!-- Phone -->
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 border border-gold/30 rounded-full flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-charcoal mb-1">
                    <span data-lang-bg>Телефон</span>
                    <span data-lang-en>Phone</span>
                  </p>
                  <a href={`tel:${t.contacts.info.phone.replace(/\s/g, '')}`} class="text-stone hover:text-gold transition-colors">
                    {t.contacts.info.phone}
                  </a>
                </div>
              </div>

              <!-- Email -->
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 border border-gold/30 rounded-full flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-charcoal mb-1">Email</p>
                  <a href={`mailto:${t.contacts.info.email}`} class="text-stone hover:text-gold transition-colors">
                    {t.contacts.info.email}
                  </a>
                </div>
              </div>

              <!-- Working hours -->
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 border border-gold/30 rounded-full flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-charcoal mb-1">
                    <span data-lang-bg>Работно време</span>
                    <span data-lang-en>Working Hours</span>
                  </p>
                  <p class="text-stone">
                    <span data-lang-bg>{t.contacts.info.workingHours.bg}</span>
                    <span data-lang-en>{t.contacts.info.workingHours.en}</span>
                  </p>
                </div>
              </div>

              <!-- WhatsApp / Viber -->
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 border border-gold/30 rounded-full flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-gold" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                </div>
                <div>
                  <p class="font-semibold text-charcoal mb-1">WhatsApp & Viber</p>
                  <a
                    href={`https://wa.me/${t.contacts.info.phone.replace(/[\s+]/g, '')}`}
                    class="text-stone hover:text-gold transition-colors"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {t.contacts.info.phone}
                  </a>
                </div>
              </div>
            </div>

            <!-- Social media -->
            <div class="mb-10">
              <p class="font-semibold text-charcoal mb-4">
                <span data-lang-bg>Социални мрежи</span>
                <span data-lang-en>Social Media</span>
              </p>
              <div class="flex gap-4">
                <a href="#" class="w-11 h-11 border border-charcoal/20 rounded-full flex items-center justify-center text-charcoal hover:border-gold hover:text-gold transition-all" aria-label="Facebook">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
                </a>
                <a href="#" class="w-11 h-11 border border-charcoal/20 rounded-full flex items-center justify-center text-charcoal hover:border-gold hover:text-gold transition-all" aria-label="Instagram">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5" stroke-width="1.5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z" stroke-width="1.5"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5" stroke-width="1.5"/></svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Map -->
    <section class="h-80 md:h-96 bg-charcoal-light">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d11729.345!2d23.29!3d42.64!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x40aa856e9c4292ef%3A0x400a01269bf5e60!2sDragalevtsi%2C%20Sofia!5e0!3m2!1sen!2sbg!4v1"
        width="100%"
        height="100%"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Montierra Location — Dragalevtsi, Sofia"
      ></iframe>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn')!;
  const statusDiv = document.getElementById('form-status')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const lang = document.documentElement.getAttribute('data-lang') || 'bg';
    submitBtn.setAttribute('disabled', 'true');
    submitBtn.innerHTML = lang === 'bg' ? 'Изпращане...' : 'Sending...';

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (response.ok) {
        statusDiv.classList.remove('hidden', 'bg-sold/10', 'text-sold');
        statusDiv.classList.add('bg-success/10', 'text-success');
        statusDiv.textContent = lang === 'bg'
          ? 'Съобщението е изпратено успешно!'
          : 'Message sent successfully!';
        form.reset();
      } else {
        throw new Error('Form submission failed');
      }
    } catch {
      statusDiv.classList.remove('hidden', 'bg-success/10', 'text-success');
      statusDiv.classList.add('bg-sold/10', 'text-sold');
      statusDiv.textContent = lang === 'bg'
        ? 'Възникна грешка. Моля, опитайте отново.'
        : 'An error occurred. Please try again.';
    } finally {
      submitBtn.removeAttribute('disabled');
      submitBtn.innerHTML = `<span data-lang-bg>${lang === 'bg' ? 'Изпрати' : ''}</span><span data-lang-en>${lang === 'en' ? 'Send' : ''}</span>`;
      // Re-apply language visibility
      const bgSpan = submitBtn.querySelector('[data-lang-bg]') as HTMLElement;
      const enSpan = submitBtn.querySelector('[data-lang-en]') as HTMLElement;
      if (bgSpan) bgSpan.textContent = 'Изпрати';
      if (enSpan) enSpan.textContent = 'Send';
    }
  });
</script>
