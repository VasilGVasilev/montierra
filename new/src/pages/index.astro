---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { t } from '../i18n/translations';
import GalleryLightbox from '../components/GalleryLightbox.astro';
---

<Layout title="Montierra — Бутиково жилищно строителство в Драгалевци">
  <Header currentPage="home" />

  <main class="flex-1">
    <!-- Hero Section -->
    <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
      <img
        src="/images/visualizations/2.jpg"
        alt="Montierra Residence"
        class="absolute inset-0 w-full h-full object-cover"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-dark/85 via-dark/45 to-dark/25"></div>

      <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
        <!-- <div class="flex justify-center mb-6 reveal">
          <img src="/logo.JPG" alt="Montierra Luxury Residence" class="h-28 w-28 md:h-36 md:w-36 object-cover rounded-sm shadow-2xl" />
        </div> -->
        <p class="text-gold text-lg md:text-2xl uppercase tracking-[0.5em] font-bold [text-shadow:-1px_-1px_0_#000,1px_-1px_0_#000,-1px_1px_0_#000,1px_1px_0_#000] mb-6 reveal reveal-delay-1">
          <span data-lang-bg>{t.home.location.bg}</span>
          <span data-lang-en>{t.home.location.en}</span>
        </p>
        <p class="text-lg md:text-xl text-white/70 max-w-2xl mx-auto mb-10 leading-relaxed reveal reveal-delay-2">
          <span data-lang-bg>{t.home.tagline.bg}</span>
          <span data-lang-en>{t.home.tagline.en}</span>
        </p>
        <a
          href="/apartments/"
          class="inline-block px-8 py-4 bg-gold text-charcoal font-semibold text-sm uppercase tracking-wider hover:bg-gold-light transition-all duration-300 reveal reveal-delay-3"
        >
          <span data-lang-bg>{t.home.cta.bg}</span>
          <span data-lang-en>{t.home.cta.en}</span>
        </a>

        <!-- Scroll indicator -->
        <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 reveal reveal-delay-4">
          <div class="w-px h-12 bg-gradient-to-b from-transparent to-gold/50"></div>
          <div class="w-2 h-2 rounded-full bg-gold/50 animate-bounce"></div>
        </div>
      </div>
    </section>

    <!-- Gallery Section -->
    <section class="bg-charcoal py-16 md:py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-6 mb-8 reveal">
          <h2 class="text-xl md:text-2xl font-heading font-semibold text-white whitespace-nowrap">
            <span data-lang-bg>{t.home.gallery.title.bg}</span>
            <span data-lang-en>{t.home.gallery.title.en}</span>
          </h2>
          <div class="h-px flex-1 bg-gold/20"></div>
        </div>
        <GalleryLightbox />
      </div>
    </section>

    <!-- Features Section -->
    <section class="py-20 md:py-28 bg-cream">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
          <!-- Location -->
          <div class="text-center p-8 reveal">
            <div class="w-16 h-16 mx-auto mb-6 border border-gold/30 rounded-full flex items-center justify-center">
              <svg class="w-7 h-7 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-heading font-semibold text-charcoal mb-3">
              <span data-lang-bg>{t.home.features.location.title.bg}</span>
              <span data-lang-en>{t.home.features.location.title.en}</span>
            </h3>
            <p class="text-stone text-sm leading-relaxed">
              <span data-lang-bg>{t.home.features.location.desc.bg}</span>
              <span data-lang-en>{t.home.features.location.desc.en}</span>
            </p>
          </div>

          <!-- Quality -->
          <div class="text-center p-8 reveal reveal-delay-1">
            <div class="w-16 h-16 mx-auto mb-6 border border-gold/30 rounded-full flex items-center justify-center">
              <svg class="w-7 h-7 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
              </svg>
            </div>
            <h3 class="text-xl font-heading font-semibold text-charcoal mb-3">
              <span data-lang-bg>{t.home.features.quality.title.bg}</span>
              <span data-lang-en>{t.home.features.quality.title.en}</span>
            </h3>
            <p class="text-stone text-sm leading-relaxed">
              <span data-lang-bg>{t.home.features.quality.desc.bg}</span>
              <span data-lang-en>{t.home.features.quality.desc.en}</span>
            </p>
          </div>

          <!-- Views -->
          <div class="text-center p-8 reveal reveal-delay-2">
            <div class="w-16 h-16 mx-auto mb-6 border border-gold/30 rounded-full flex items-center justify-center">
              <svg class="w-7 h-7 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-heading font-semibold text-charcoal mb-3">
              <span data-lang-bg>{t.home.features.views.title.bg}</span>
              <span data-lang-en>{t.home.features.views.title.en}</span>
            </h3>
            <p class="text-stone text-sm leading-relaxed">
              <span data-lang-bg>{t.home.features.views.desc.bg}</span>
              <span data-lang-en>{t.home.features.views.desc.en}</span>
            </p>
          </div>

          <!-- Parking -->
          <div class="text-center p-8 reveal reveal-delay-3">
            <div class="w-16 h-16 mx-auto mb-6 border border-gold/30 rounded-full flex items-center justify-center">
              <svg class="w-7 h-7 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <h3 class="text-xl font-heading font-semibold text-charcoal mb-3">
              <span data-lang-bg>{t.home.features.parking.title.bg}</span>
              <span data-lang-en>{t.home.features.parking.title.en}</span>
            </h3>
            <p class="text-stone text-sm leading-relaxed">
              <span data-lang-bg>{t.home.features.parking.desc.bg}</span>
              <span data-lang-en>{t.home.features.parking.desc.en}</span>
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- About Teaser -->
    <section class="py-20 md:py-28 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
          <!-- Building rear/garden view -->
          <div class="aspect-[4/3] rounded-sm overflow-hidden reveal">
            <img
              src="/images/visualizations/1.jpg"
              alt="Montierra garden view"
              class="w-full h-full object-cover hover:scale-[1.04] transition-transform duration-700"
            />
          </div>

          <!-- Text content -->
          <div class="reveal reveal-delay-1">
            <p class="text-gold text-sm uppercase tracking-[0.2em] mb-4">
              <span data-lang-bg>{t.home.about.label.bg}</span>
              <span data-lang-en>{t.home.about.label.en}</span>
            </p>
            <h2 class="text-3xl md:text-4xl font-heading font-semibold text-charcoal mb-6 leading-tight">
              <span data-lang-bg>{t.home.about.title.bg}</span>
              <span data-lang-en>{t.home.about.title.en}</span>
            </h2>
            <p class="text-stone leading-relaxed mb-8">
              <span data-lang-bg>{t.home.about.text.bg}</span>
              <span data-lang-en>{t.home.about.text.en}</span>
            </p>
            <a
              href="/description/"
              class="inline-flex items-center gap-2 text-gold hover:text-gold-dark transition-colors font-medium text-sm uppercase tracking-wider"
            >
              <span data-lang-bg>{t.home.about.link.bg}</span>
              <span data-lang-en>{t.home.about.link.en}</span>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="py-16 md:py-20 bg-charcoal">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
          <div class="reveal">
            <p class="text-3xl md:text-4xl font-heading font-bold text-gold">8</p>
            <p class="text-white/60 text-sm mt-2 uppercase tracking-wider">
              <span data-lang-bg>{t.home.stats.apartments.bg}</span>
              <span data-lang-en>{t.home.stats.apartments.en}</span>
            </p>
          </div>
          <div class="reveal reveal-delay-1">
            <p class="text-3xl md:text-4xl font-heading font-bold text-gold">4</p>
            <p class="text-white/60 text-sm mt-2 uppercase tracking-wider">
              <span data-lang-bg>{t.home.stats.floors.bg}</span>
              <span data-lang-en>{t.home.stats.floors.en}</span>
            </p>
          </div>
          <div class="reveal reveal-delay-2">
            <p class="text-3xl md:text-4xl font-heading font-bold text-gold">8</p>
            <p class="text-white/60 text-sm mt-2 uppercase tracking-wider">
              <span data-lang-bg>{t.home.stats.garages.bg}</span>
              <span data-lang-en>{t.home.stats.garages.en}</span>
            </p>
          </div>
          <div class="reveal reveal-delay-3">
            <p class="text-3xl md:text-4xl font-heading font-bold text-gold">2026</p>
            <p class="text-white/60 text-sm mt-2 uppercase tracking-wider">
              <span data-lang-bg>{t.home.stats.completion.bg}</span>
              <span data-lang-en>{t.home.stats.completion.en}</span>
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
