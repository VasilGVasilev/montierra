---
import { t } from '../i18n/translations';

const navItems = [
  { href: '/', label: t.nav.home },
  { href: '/description/', label: t.nav.description },
  { href: '/investor/', label: t.nav.investor },
  { href: '/apartments/', label: t.nav.apartments },
  { href: '/contacts/', label: t.nav.contacts },
];

const year = new Date().getFullYear();
---

<footer class="bg-charcoal text-white/70">
  <!-- Main footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-block">
          <img src="/logo.JPG" alt="Montierra Luxury Residence" class="h-20 w-20 object-cover rounded-sm opacity-90 hover:opacity-100 transition-opacity" />
        </a>
        <p class="mt-4 text-sm leading-relaxed" data-lang-bg>
          Бутикова жилищна сграда в Драгалевци, София. Изключително качество и внимание към детайла.
        </p>
        <p class="mt-4 text-sm leading-relaxed" data-lang-en>
          Boutique residential building in Dragalevtsi, Sofia. Exceptional quality and attention to detail.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="text-white font-heading text-lg mb-4">
          <span data-lang-bg>Навигация</span>
          <span data-lang-en>Navigation</span>
        </h3>
        <ul class="space-y-2">
          {navItems.map((item) => (
            <li>
              <a href={item.href} class="text-sm hover:text-gold transition-colors">
                <span data-lang-bg>{item.label.bg}</span>
                <span data-lang-en>{item.label.en}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact info -->
      <div>
        <h3 class="text-white font-heading text-lg mb-4">
          <span data-lang-bg>Контакти</span>
          <span data-lang-en>Contacts</span>
        </h3>
        <ul class="space-y-3 text-sm">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 text-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>
              <span data-lang-bg>{t.contacts.info.address.bg}</span>
              <span data-lang-en>{t.contacts.info.address.en}</span>
            </span>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href={`tel:${t.contacts.info.phone.replace(/\s/g, '')}`} class="hover:text-gold transition-colors">
              {t.contacts.info.phone}
            </a>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gold shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href={`mailto:${t.contacts.info.email}`} class="hover:text-gold transition-colors">
              {t.contacts.info.email}
            </a>
          </li>
        </ul>
      </div>

      <!-- Social -->
      <div>
        <h3 class="text-white font-heading text-lg mb-4">
          <span data-lang-bg>Социални мрежи</span>
          <span data-lang-en>Social Media</span>
        </h3>
        <div class="flex gap-4">
          <a href="#" class="w-10 h-10 border border-white/20 rounded-full flex items-center justify-center hover:border-gold hover:text-gold transition-all" aria-label="Facebook">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
          <a href="#" class="w-10 h-10 border border-white/20 rounded-full flex items-center justify-center hover:border-gold hover:text-gold transition-all" aria-label="Instagram">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5" stroke-width="1.5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z" stroke-width="1.5"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5" stroke-width="1.5"/></svg>
          </a>
      
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs">
        &copy; {year} Montierra.
        <span data-lang-bg>{t.footer.rights.bg}</span>
        <span data-lang-en>{t.footer.rights.en}</span>
      </p>
 
    </div>
  </div>
</footer>
